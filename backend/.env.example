# Supabase Transaction Pooler connection string (port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"
JWT_SECRET="replace-with-a-random-secret-at-least-32-characters"

# Local values use LAN automatically. On Vercel, enter the deployed HTTPS URLs.
CUSTOMER_APP_URL="https://le-monde-steak-customer.vercel.app"
BACKEND_PUBLIC_URL="https://le-monde-steak-api.vercel.app"

# Optional: kept for future direct Supabase/Cloudinary integrations.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
