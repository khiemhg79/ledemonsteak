generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum TableStatus {
  EMPTY
  OCCUPIED
  REQUESTING_BILL
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OrderDetailStatus {
  WAITING
  PREPARING
  DONE
  SERVED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  E_WALLET
}

model UserRole {
  id          String   @id
  name        String   @unique @map("roleName")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id          String    @id @default(cuid())
  name        String    @map("username")
  phone       String    @unique
  password    String
  email       String?
  role        Role      @default(CUSTOMER)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
  customer    Customer?

  @@map("users")
}

model Customer {
  id            String    @id @default(cuid())
  userId        String?   @unique
  name          String    @map("fullName")
  phone         String    @unique
  email         String?
  address       String?
  city          String?
  district      String?
  birthday      DateTime? @map("dateOfBirth")
  customerType  String    @default("GUEST")
  loyaltyPoints Int       @default(0)
  totalSpent    Float     @default(0)
  isActive      Boolean   @default(true)
  user          User?     @relation(fields: [userId], references: [id])
  orders        Order[]
  invoices      Invoice[]

  @@map("customers")
}

model Table {
  id        String      @id @default(cuid())
  number    String      @unique @map("tableNumber")
  capacity  Int         @default(2)
  status    String      @default("EMPTY")
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  orders    Order[]
  invoices  Invoice[]

  @@map("tables")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @map("categoryName")
  desc      String?  @map("description")
  image     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     Item[]

  @@map("categories")
}

model Item {
  id          String   @id @default(cuid())
  name        String
  price       Float
  description String?
  image       String?
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  @@map("items")
}

model Combo {
  id          String   @id @default(cuid())
  name        String
  price       Float
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("combos")
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   Int           @unique @default(autoincrement())
  tableId       String?
  userId        String?
  customerId    String?
  status        String        @default("PENDING") @map("orderStatus")
  totalAmount   Float         @default(0) @map("subTotal")
  taxAmount     Float         @default(0)
  serviceCharge Float         @default(0)
  discount      Float         @default(0) @map("discountAmount")
  finalAmount   Float         @default(0) @map("totalAmount")
  promoCode     String?
  customerNotes String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  table         Table?        @relation(fields: [tableId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])
  customer      Customer?     @relation(fields: [customerId], references: [id])
  invoice       Invoice?
  payments      Payment[]

  @@map("orders")
}

model Promotion {
  id            String       @id @default(cuid())
  name          String
  discountType  String       @default("PERCENTAGE") @map("type")
  discountValue Float        @map("value")
  minOrder      Float        @default(0) @map("minOrderAmount")
  maxDiscount   Float?
  usageLimit    Int?
  usageCount    Int          @default(0) @map("usedCount")
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean      @default(true)
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("promotions")
}

model Invoice {
  id              String         @id @default(cuid())
  invoiceCode     String         @unique @map("invoiceNumber")
  orderId         String?        @unique
  customerId      String?
  tableId         String?
  subtotal        Float          @default(0) @map("subTotal")
  customerName    String?
  customerTaxCode String?
  taxAmount       Float          @default(0)
  total           Float          @default(0) @map("totalAmount")
  paymentMethod   String?
  status          InvoiceStatus  @default(UNPAID)
  issuedAt        DateTime       @default(now()) @map("createdAt")
  updatedAt       DateTime       @updatedAt
  paidAt          DateTime?
  note            String?
  order           Order?         @relation(fields: [orderId], references: [id])
  customer        Customer?      @relation(fields: [customerId], references: [id])
  table           Table?         @relation(fields: [tableId], references: [id])
  payments        Payment[]

  @@map("invoices")
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String?
  orderId         String?
  method          String        @default("CASH") @map("paymentMethod")
  amount          Float
  paidAmount      Float         @default(0)
  changeAmount    Float         @default(0)
  status          String        @default("PENDING") @map("paymentStatus")
  paidAt          DateTime?
  transactionCode String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])

  @@map("payments")
}
